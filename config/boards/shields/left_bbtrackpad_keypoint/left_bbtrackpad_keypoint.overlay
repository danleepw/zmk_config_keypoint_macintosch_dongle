/ {
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        bbtrackpad_split: bbtrackpad_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };

    };

    /* Listeners */
    bbtrackpad_listener: bbtrackpad_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&bbtrackpad_split>;
    };

};


&bbtrackpad_split {
    device = <&bbtrackpad>;
};


&pinctrl {
    pwm1_default:pwm1_default{
        group1{
            psels = <NRF_PSEL(PWM_OUT0, 1, 9)>; // Backlight for Trackpad
        };
    };

    pwm1_sleep: pwm1_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 1, 9)>;
            bias-pull-down;
        };
    };

    pwm2_default:pwm2_default{
        group1{
            psels = <NRF_PSEL(PWM_OUT0, 0, 7)>; // GPIO for custom led
        };
    };

    pwm2_sleep: pwm2_sleep {
        group1 {
            psels = <NRF_PSEL(PWM_OUT0, 0, 7)>;
            bias-pull-down;
        };
    };

    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 26)>,
                <NRF_PSEL(TWIM_SCL, 0, 4)>;
        };
    };

    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 26)>,
                <NRF_PSEL(TWIM_SCL, 0, 4)>;
            low-power-enable;
        };
    };
};


